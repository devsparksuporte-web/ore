NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui

# Opcional: só necessário se for usar o envio de boletos para o Google Drive.
# Veja o passo a passo no README na seção "Google Drive (opcional)".
# Vem do arquivo JSON baixado em APIs e Serviços > Credenciais > ID do
# cliente OAuth (tipo "Aplicativo Web"), não da conta de serviço.
GOOGLE_OAUTH_CLIENT_ID=algo.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxx
GOOGLE_OAUTH_REDIRECT_URI=https://SEU-APP.vercel.app/api/google-auth/callback
# Esse aqui só é gerado depois: um admin visita /api/google-auth logado no
# app, autoriza no Google com a conta dona da pasta, e cola o token mostrado
# na tela aqui.
GOOGLE_OAUTH_REFRESH_TOKEN=

GOOGLE_DRIVE_FOLDER_ID=id-da-pasta-no-drive
